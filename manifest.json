{
  "manifest_version": 3,
  "name": "Google Meet Auto Unmute",
  "version": "1.0.7",
  "description": "Automatically unmutes you in Google Meet when you start talking while muted, using mouth-movement and speech detection.",
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://meet.google.com/*"],
  "web_accessible_resources": [
    {
      "resources": [
        "auto_unmute.html",
        "auto_unmute.js",
        "js/face-api.min.js",
        "models/*"
      ],
      "matches": ["https://meet.google.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Auto Unmute settings",
    "default_icon": {
      "16": "images/off16.png",
      "32": "images/off32.png"
    }
  }
}
